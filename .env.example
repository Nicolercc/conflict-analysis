# --- API server (@workspace/api-server) ---
# Required. Platform-provided port in production.
PORT=3001
# Use `production` in deployed API (JSON logs). Use `development` locally for readable logs.
NODE_ENV=development
# Optional: pino log level (default info)
# LOG_LEVEL=info

# Required at process start (validated when intelligence routes load).
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com
AI_INTEGRATIONS_ANTHROPIC_API_KEY=your-key-here

# Reserved for future DB-backed features (optional today).
DATABASE_URL=your-db-url-here

# --- Vantage frontend (build-time; Vite) ---
# When the UI is hosted on a different origin than the API, set this before
# `pnpm --filter @workspace/vantage run build` (no trailing slash).
# Leave unset for same-origin / reverse-proxied /api (e.g. local dev with Vite proxy).
# VITE_API_BASE_URL=https://api.example.com
